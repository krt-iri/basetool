# Copy this file to .env and fill in real values.
# .env must NEVER be committed.
# Generate strong passwords, e.g.:  openssl rand -base64 32
#
# All values below are required (docker-compose will fail-fast if any is missing).

# Backend Database configuration
POSTGRES_DB=krt_basetool
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

# Keycloak Database configuration
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=CHANGE_ME
KC_POSTGRES_PASSWORD=CHANGE_ME

# Keycloak Initial Admin User
KC_BOOTSTRAP_ADMIN_USERNAME=CHANGE_ME
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME

# Keycloak admin-API client secret (used by backend to sync users).
# Get / rotate this in the Keycloak admin console:
#   Realm "iri" -> Clients -> backend-service -> Credentials -> Regenerate.
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGE_ME

# PKCS12 keystore password for backend + frontend Spring SSL.
# The keystore file itself (keystore.p12) is .gitignore'd and must be
# provided out-of-band (e.g. mounted into the container).
SERVER_SSL_KEY_STORE_PASSWORD=CHANGE_ME

# Host IP for outbound binding (set to the deployment host IP)
HOST_IP=CHANGE_ME

# Redis password
REDIS_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Optional: only needed when running backend OUTSIDE docker-compose
# (e.g. ./gradlew :backend:bootRun --args=--spring.profiles.active=dev).
# Inside compose, these are set automatically from POSTGRES_USER/PASSWORD.
# ---------------------------------------------------------------------------
# SPRING_DATASOURCE_USERNAME=CHANGE_ME
# SPRING_DATASOURCE_PASSWORD=CHANGE_ME
