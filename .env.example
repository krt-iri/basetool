# Copy this file to .env and fill in real values.
# .env must NEVER be committed.
# Generate strong passwords, e.g.:  openssl rand -base64 32
#
# All values below are required (docker-compose will fail-fast if any is missing).

# Backend Database configuration
POSTGRES_DB=krt_basetool
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

# Keycloak Database configuration
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=CHANGE_ME
KC_POSTGRES_PASSWORD=CHANGE_ME

# Keycloak Initial Admin User
KC_BOOTSTRAP_ADMIN_USERNAME=CHANGE_ME
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME

# Keycloak admin-API client secret (used by backend to sync users).
# Get / rotate this in the Keycloak admin console:
#   Realm "iri" -> Clients -> backend-service -> Credentials -> Regenerate.
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGE_ME

# PKCS12 keystore password for backend + frontend Spring SSL.
# The keystore file itself (keystore.p12) is .gitignore'd and must be
# provided out-of-band as a bind mount (see IRI_KEYSTORE_HOST_PATH below) —
# the keystore is NEVER baked into the GHCR image (see CLAUDE.md and the
# .dockerignore at the repo root for the threat model).
SERVER_SSL_KEY_STORE_PASSWORD=CHANGE_ME

# Absolute host path to the production keystore.p12. Bind-mounted read-only
# into both backend and frontend containers at /run/secrets/keystore.p12.
# Owner should be the runtime user (uid 10001) or `o+r` so the JVM can read
# the file. On a production host the canonical location is
# /var/iri/secrets/keystore.p12; for local dev, the default (`./keystore.p12`)
# resolves relative to docker-compose.yml and a generated test keystore at
# the repo root works out of the box.
IRI_KEYSTORE_HOST_PATH=/var/iri/secrets/keystore.p12

# Host IP for outbound binding (set to the deployment host IP)
HOST_IP=CHANGE_ME

# Redis password
REDIS_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Image-pull configuration (consumed by docker-compose.yml on the prod host)
# ---------------------------------------------------------------------------
# GHCR namespace that owns the basetool-backend / basetool-frontend packages.
# Default `krt-iri` matches the GitHub organisation that publishes the
# production images via .github/workflows/release-images.yml — override only
# when running against a fork's own GHCR namespace.
IRI_IMAGE_NAMESPACE=krt-iri

# Version pointer that resolves to a concrete GHCR tag. The deploy.sh script
# leaves this unset by default so the host follows the rolling `:stable`
# pointer that is updated atomically by .github/workflows/promote.yml.
# Pin to a specific version (`1.4.2`, `sha-abc1234`, ...) to roll back or
# stage an earlier release. Tags are immutable per digest, so a pinned
# version always resolves to the same image.
#IRI_BASETOOL_VERSION=stable

# ---------------------------------------------------------------------------
# Optional: only needed when running backend OUTSIDE docker-compose
# (e.g. ./gradlew :backend:bootRun --args=--spring.profiles.active=dev).
# Inside compose, these are set automatically from POSTGRES_USER/PASSWORD.
# ---------------------------------------------------------------------------
# SPRING_DATASOURCE_USERNAME=CHANGE_ME
# SPRING_DATASOURCE_PASSWORD=CHANGE_ME
