<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <property name="LOG_FILE" value="logs/backend.log"/>
    <property name="LOG_ERROR_FILE" value="logs/backend-error.log"/>

    <!--
      MDC-enriched pattern.
      - %X{correlationId:-} renders the per-request correlation id set by CorrelationIdFilter.
      - %X{userId:-anonymous} renders the JWT `sub` of the authenticated user (or "anonymous").
      - %X{orgUnitId:-} renders the active OrgUnit context (audit finding L-5 / CLAUDE.md
        section 7 logging requirement). Empty for anonymous callers and admins in "all OrgUnits"
        mode; the bracket stays so the column position is stable for log parsing.
      These three fields are the audit-trail backbone for multi-tenant incident triage.
    -->
    <property name="LOG_PATTERN_CONSOLE" value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr([%X{correlationId:-}]){magenta} %clr([%X{userId:-anonymous}]){blue} %clr([%X{orgUnitId:-}]){cyan} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>
    <property name="LOG_PATTERN_FILE" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%X{correlationId:-}] [%X{userId:-anonymous}] [%X{orgUnitId:-}] --- [%t] %-40.40logger{39} : %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="de.greluc.krt.profit.basetool.backend.logging.PiiMaskingPatternLayout">
                <pattern>${LOG_PATTERN_CONSOLE}</pattern>
            </layout>
        </encoder>
    </appender>

    <!--
      Size-and-time based rolling replaces the previous FixedWindowRollingPolicy, which raised
      the "Large window sizes are not allowed" warning observed in production log.txt.
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/backend.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="de.greluc.krt.profit.basetool.backend.logging.PiiMaskingPatternLayout">
                <pattern>${LOG_PATTERN_FILE}</pattern>
            </layout>
        </encoder>
    </appender>

    <!--
      Dedicated ERROR-only appender. Lets support quickly scan incidents without wading through
      the full INFO stream.
    -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_ERROR_FILE}</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/backend-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="de.greluc.krt.profit.basetool.backend.logging.PiiMaskingPatternLayout">
                <pattern>${LOG_PATTERN_FILE}</pattern>
            </layout>
        </encoder>
    </appender>

    <!--
      Async wrappers for the disk-backed appenders. The request thread now hands the formatted
      event to a bounded queue instead of blocking on file I/O / PII-masking layout work; a single
      dedicated worker drains the queue. discardingThreshold=0 means no event is ever dropped from
      the queue (audit-trail integrity over throughput) — the queue is sized generously so this
      only matters under extreme sustained load, at which point the calling thread backpressures
      rather than losing audit data. CONSOLE stays synchronous on purpose: stdout is cheap and we
      want the last lines before a JVM crash to flush deterministically.
    -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FILE" />
    </appender>

    <appender name="ASYNC_ERROR_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>128</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="ERROR_FILE" />
    </appender>

    <!--
      Optional structured JSON appender, enabled for the `prod` Spring profile via
      <springProfile>. LogstashEncoder preserves all MDC entries (correlationId, userId) as
      first-class JSON fields so ELK/Loki/CloudWatch can index them natively. The feature flag
      `app.logging.structured-enabled` documents the same switch at application level for the
      banner / health endpoint.
    -->
    <springProfile name="prod">
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/backend.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/backend.%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="de.greluc.krt.profit.basetool.backend.logging.PiiMaskingLogstashEncoder">
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <!-- L-5: orgUnitId on the structured JSON appender so log shippers can index the
                     active OrgUnit context as a first-class field. -->
                <includeMdcKeyName>orgUnitId</includeMdcKeyName>
                <customFields>{"app":"basetool-backend"}</customFields>
            </encoder>
        </appender>

        <appender name="ASYNC_JSON_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <appender-ref ref="JSON_FILE" />
        </appender>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR_FILE" />
            <appender-ref ref="ASYNC_JSON_FILE" />
        </root>
    </springProfile>
    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR_FILE" />
        </root>
    </springProfile>

    <!--
      Default application log level. TRACE in prod (the previous value) wrote DEBUG/TRACE calls
      from controller/, service/, config/ and security/ on every request — several of those call
      sites log JWT attributes / squadron context / principal names, which made prod log volume
      explode and dominated request latency through the synchronous appender chain. The frontend
      module's logback-spring.xml was already corrected to INFO (audit finding H-11); this brings
      the backend in line. Engineers can narrow to DEBUG/TRACE per sub-package via env override
      (`logging.level.de.greluc.krt.profit.basetool.<pkg>=DEBUG`) when triaging a specific incident.
    -->
    <logger name="de.greluc.krt.profit.basetool" level="INFO" />
    <logger name="org.springframework.web" level="INFO" />
    <logger name="org.springframework.security" level="INFO" />

</configuration>
