  "clients": [
    {
      "clientId": "basetool-frontend",
      "name": "IRIDIUM Basetool Frontend",
      "description": "Frontend Application for IRIDIUM Basetool",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "https://basetool.example.invalid/login/oauth2/code/keycloak",
        "https://basetool.example.invalid/*",
        "http://frontend:18081/*"
      ],
      "webOrigins": [
        "https://basetool.example.invalid",
        "http://frontend:18081"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://basetool.example.invalid/*##https://basetool.example.invalid",
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "false",
        "backchannel.logout.revoke.offline.tokens": "false"
      },
      "protocolMappers": [
        {
          "name": "rank",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "rank",
            "claim.name": "rank",
            "jsonType.label": "int",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "description",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "description",
            "claim.name": "description",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "config": {
            "lightweight.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "_comment": "ADR-0036: sourced from the Keycloak federated-identity link via the SPI DiscordFederatedIdentityMapper (protocolMapper id 'discord-federated-identity-mapper'), NOT from the imported user attribute, so the claim is present for accounts linked at any time and on every login method. Replaces the former oidc-usermodel-attribute-mapper on 'discord_user_id'.",
          "name": "discord_user_id",
          "protocol": "openid-connect",
          "protocolMapper": "discord-federated-identity-mapper",
          "config": {
            "idp.alias": "discord",
            "claim.name": "discord_user_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "discord_guild_nickname",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "discord_guild_nickname",
            "claim.name": "discord_guild_nickname",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
