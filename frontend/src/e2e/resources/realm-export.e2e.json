{
  "realm": "iri",
  "displayName": "IRI (E2E TEST REALM - throwaway, do not use in prod)",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 36000,
  "ssoSessionMaxLifespan": 36000,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 5,
  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 90,
      "config": {}
    }
  ],
  "roles": {
    "realm": [
      { "name": "Admin", "description": "E2E test role" },
      { "name": "Officer", "description": "E2E test role" },
      { "name": "Logistician", "description": "E2E test role" },
      { "name": "Mission Manager", "description": "E2E test role" },
      { "name": "Squadron Member", "description": "E2E test role" },
      { "name": "Guest", "description": "E2E test role" },
      { "name": "Bank Employee", "description": "E2E test role" },
      { "name": "Bank Management", "description": "E2E test role" }
    ]
  },
  "clients": [
    {
      "clientId": "basetool-frontend",
      "name": "Basetool Frontend (E2E)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "redirectUris": [
        "https://localhost:18081/*",
        "https://frontend:18081/*",
        "https://host.docker.internal:18081/*",
        "http://localhost:18081/*",
        "http://frontend:18081/*",
        "http://host.docker.internal:18081/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "rank",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "rank",
            "claim.name": "rank",
            "jsonType.label": "int",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "description",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "description",
            "claim.name": "description",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "basetool-sc-extractor",
      "name": "Basetool SC Extractor (E2E)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "redirectUris": ["http://127.0.0.1/*", "http://localhost/*"],
      "webOrigins": [],
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["web-origins", "roles", "profile", "email", "extractor-ingest"]
    },
    {
      "clientId": "backend-service",
      "name": "Backend Service Account (E2E)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "e2e-client-secret-do-not-use-in-prod",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true
    }
  ],
  "clientScopes": [
    {
      "name": "extractor-ingest",
      "description": "Stamps aud=basetool-backend on access tokens (desktop ingest, REQ-INGEST-008).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-basetool-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "basetool-backend",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "test-admin",
      "enabled": true,
      "emailVerified": true,
      "email": "test-admin@example.test",
      "credentials": [
        { "type": "password", "value": "test-admin-pw", "temporary": false }
      ],
      "realmRoles": ["Admin", "Officer", "Squadron Member"]
    },
    {
      "username": "test-officer",
      "enabled": true,
      "emailVerified": true,
      "email": "test-officer@example.test",
      "credentials": [
        { "type": "password", "value": "test-officer-pw", "temporary": false }
      ],
      "realmRoles": ["Officer", "Squadron Member"]
    },
    {
      "username": "test-member",
      "enabled": true,
      "emailVerified": true,
      "email": "test-member@example.test",
      "credentials": [
        { "type": "password", "value": "test-member-pw", "temporary": false }
      ],
      "realmRoles": ["Squadron Member"]
    },
    {
      "username": "test-sk",
      "enabled": true,
      "emailVerified": true,
      "email": "test-sk@example.test",
      "credentials": [
        { "type": "password", "value": "test-sk-pw", "temporary": false }
      ],
      "realmRoles": ["Squadron Member"]
    },
    {
      "username": "test-none",
      "enabled": true,
      "emailVerified": true,
      "email": "test-none@example.test",
      "credentials": [
        { "type": "password", "value": "test-none-pw", "temporary": false }
      ],
      "realmRoles": ["Squadron Member"]
    },
    {
      "username": "test-both",
      "enabled": true,
      "emailVerified": true,
      "email": "test-both@example.test",
      "credentials": [
        { "type": "password", "value": "test-both-pw", "temporary": false }
      ],
      "realmRoles": ["Squadron Member"]
    },
    {
      "username": "test-bank-employee",
      "enabled": true,
      "emailVerified": true,
      "email": "test-bank-employee@example.test",
      "credentials": [
        { "type": "password", "value": "test-bank-employee-pw", "temporary": false }
      ],
