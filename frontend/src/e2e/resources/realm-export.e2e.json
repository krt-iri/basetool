      "email": "test-bank-management@example.test",
      "credentials": [
        { "type": "password", "value": "test-bank-management-pw", "temporary": false }
      ],
      "realmRoles": ["Bank Management"]
    },
    {
      "username": "test-bank-member",
      "enabled": true,
      "emailVerified": true,
      "email": "test-bank-member@example.test",
      "credentials": [
        { "type": "password", "value": "test-bank-member-pw", "temporary": false }
      ],
      "realmRoles": ["Bank Employee", "Squadron Member"]
    }
  ]
}
