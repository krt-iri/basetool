<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />
    <property name="LOG_FILE" value="logs/frontend.log"/>
    <property name="LOG_ERROR_FILE" value="logs/frontend-error.log"/>
    <!--
      MDC-enriched pattern.
      - %X{correlationId:-} renders the per-request correlation id set by CorrelationIdFilter.
      - %X{userId:-anonymous} renders the OIDC `sub` of the authenticated user (or "anonymous").
      These two fields are the single most important addition for production debugging / support.
    -->
    <property name="LOG_PATTERN_CONSOLE" value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr([%X{correlationId:-}]){magenta} %clr([%X{userId:-anonymous}]){blue} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>
    <property name="LOG_PATTERN_FILE" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%X{correlationId:-}] [%X{userId:-anonymous}] --- [%t] %-40.40logger{39} : %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="de.greluc.krt.profit.basetool.frontend.logging.PiiMaskingPatternLayout">
                <pattern>${LOG_PATTERN_CONSOLE}</pattern>
            </layout>
        </encoder>
    </appender>

    <!--
      Size-and-time based rolling replaces the previous FixedWindowRollingPolicy, which raised
      the "Large window sizes are not allowed" warning observed in log.txt.
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/frontend.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="de.greluc.krt.profit.basetool.frontend.logging.PiiMaskingPatternLayout">
                <pattern>${LOG_PATTERN_FILE}</pattern>
            </layout>
        </encoder>
    </appender>

    <!-- Dedicated ERROR-only appender for quick incident scans. -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_ERROR_FILE}</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/frontend-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="de.greluc.krt.profit.basetool.frontend.logging.PiiMaskingPatternLayout">
                <pattern>${LOG_PATTERN_FILE}</pattern>
            </layout>
        </encoder>
    </appender>

    <!--
      Async wrappers for the disk-backed appenders. The request thread now hands the formatted
      event to a bounded queue instead of blocking on file I/O / PII-masking layout work; a single
      dedicated worker drains the queue. discardingThreshold=0 means no event is ever dropped from
      the queue (audit-trail integrity over throughput) — the queue is sized generously so this
      only matters under extreme sustained load, at which point the calling thread backpressures
      rather than losing audit data. CONSOLE stays synchronous on purpose: stdout is cheap and we
      want the last lines before a JVM crash to flush deterministically.
    -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FILE" />
    </appender>

    <appender name="ASYNC_ERROR_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>128</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="ERROR_FILE" />
    </appender>

    <!-- Structured JSON appender for the `prod` profile, consumable by ELK/Loki/CloudWatch. -->
    <springProfile name="prod">
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/frontend.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/frontend.%d{yyyy-MM-dd}.%i.json.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
            <!--
              Audit M-5: use the PII-masking encoder (extends LogstashEncoder) instead of the stock
              one, so the JSON sink scrubs e-mails / JWTs / bearer tokens like the console/file
              sinks already do via PiiMaskingPatternLayout. Was the only unmasked log output.
            -->
            <encoder class="de.greluc.krt.profit.basetool.frontend.logging.PiiMaskingLogstashEncoder">
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <customFields>{"app":"basetool-frontend"}</customFields>
            </encoder>
        </appender>

        <appender name="ASYNC_JSON_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <appender-ref ref="JSON_FILE" />
        </appender>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR_FILE" />
            <appender-ref ref="ASYNC_JSON_FILE" />
        </root>
    </springProfile>
    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR_FILE" />
        </root>
    </springProfile>

    <!--
        Audit finding H-11: the application package used to default to TRACE, which meant DEBUG /
        TRACE calls in `config/` and `controller/` were written to disk in production. Several of
        those call sites log OIDC attributes / principal names / session metadata. We default to
        INFO and let an on-call engineer narrow to DEBUG/TRACE per sub-package via env override
        (`logging.level.de.greluc.krt.profit.basetool.<pkg>=DEBUG`) when triaging a specific incident.
    -->
    <logger name="de.greluc.krt.profit.basetool" level="INFO" />
    <logger name="org.springframework.web" level="INFO" />
    <logger name="org.springframework.security" level="INFO" />
    <logger name="io.github.resilience4j" level="INFO" />

</configuration>
