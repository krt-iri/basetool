# Lombok configuration — applies to both backend and frontend modules.
# https://projectlombok.org/features/configuration
#
# Treat this file as the root of the Lombok config; do not search higher.
config.stopBubbling = true

# Add @lombok.Generated to every Lombok-generated method/constructor/type so
# coverage tools (JaCoCo) and static analysers (SpotBugs, Checkstyle) can
# exclude them. JaCoCo 0.8.2+ honours any annotation named "Generated" with
# class-or-runtime retention automatically; @lombok.Generated is runtime.
#
# This removes the per-line / per-branch coverage noise from getters, setters,
# @Builder boilerplate, toString/equals/hashCode and @RequiredArgsConstructor
# — none of which carry real business logic.
lombok.addLombokGeneratedAnnotation = true
